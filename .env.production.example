# Production Environment Configuration - DO NOT COMMIT TO GIT
# Copy this file to .env.production and fill in with actual production values

# MongoDB
MONGO_URL=mongodb://mongo-user:secure-password@mongo.capeembercoffee.co.za:27017/cape_ember_coffee?authSource=admin

# Database
DB_NAME=cape_ember_coffee

# CORS Origins (comma-separated)
CORS_ORIGINS=https://capeembercoffee.co.za,https://www.capeembercoffee.co.za

# JWT Secret (generate a new one for production)
JWT_SECRET=your-secure-jwt-secret-here-min-32-chars

# PayFast Configuration (Production)
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_SANDBOX=false

# Stitch Payment Configuration (Production)
STITCH_CLIENT_ID=your-stitch-client-id
STITCH_CLIENT_SECRET=your-stitch-client-secret
STITCH_WEBHOOK_URL=https://capeembercoffee.co.za/api/webhooks/stitch
STITCH_SANDBOX=false

# Email Configuration
RESEND_API_KEY=your-resend-api-key
SENDER_EMAIL=Cape Ember Coffee <noreply@capeembercoffee.co.za>

# Frontend URL
FRONTEND_URL=https://capeembercoffee.co.za

# Analytics (optional but recommended)
REACT_APP_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Redis (optional for caching/sessions)
REDIS_URL=redis://redis-user:secure-password@redis.capeembercoffee.co.za:6379/0

# Logging
LOG_LEVEL=info
